# EchoLayer live embedder (D14). Copy to .env and fill in a key to enable real semantic recall.
# Without a key, EchoLayer falls back to a local keyword fake embedder automatically.
#
# Get a key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# GEMINI_API_KEY is also accepted as an alias.

# Rating model (D13). Used by flush to rate importance / write summaries / classify outcome.
# With an Anthropic key + credits, Claude (claude-haiku-4-5) is used; otherwise Gemini
# (gemini-2.5-flash) on the Google key above; otherwise a deterministic fake.
# ANTHROPIC_API_KEY=sk-ant-...
#
# Provider override: claude | gemini | fake. Set to 'gemini' to force the Gemini rater while
# your Anthropic account has no API credits; remove it to auto-prefer Claude.
# ECHOLAYER_RATER=gemini

# Optional: override the SQLite database path (defaults to ./echolayer.db)
# ECHOLAYER_DB=
